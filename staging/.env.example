# Staging Supabase — variables d'environnement (ne pas committer .env)
# Copier : cp staging/.env.example staging/.env

# URL publique de l'API Supabase staging (Cloud ou self-hosted)
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_URL=http://localhost:8000

# Clé anon / publishable (OK côté client)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role — UNIQUEMENT pour scripts seed serveur, jamais dans le front
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mot de passe des comptes de test seed
STAGING_SEED_PASSWORD=change-me-staging-2026

# Postgres direct (optionnel, pour apply-migrations.sh)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
